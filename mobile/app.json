{
  "expo": {
    "name": "SmartPrep",
    "slug": "smartprep",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1331"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartprep.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.smartprep.app",
      "permissions": ["RECORD_AUDIO", "CAMERA"]
    },
    "extra": {
      "apiBaseUrl": "https://backend-02-au4i.onrender.com"
    },
    "plugins": [
      [
        "expo-av",
        { "microphonePermission": "Allow SmartPrep to access your microphone." }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SmartPrep to access your camera for body language analysis.",
          "microphonePermission": "Allow SmartPrep to record your voice answers.",
          "recordAudioAndroid": true
        }
      ]
    ]
  }
}

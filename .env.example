# Variables consumed by docker-compose.yml at the repo root.
# Copy this to .env and adjust.

# Backend signing secret (required for prod)
JWT_SECRET=replace-with-a-long-random-string

# Public URL the browser will use to reach the backend.
# - Local docker-compose:  http://localhost:4000
# - Production:            https://api.your-domain.com
WEB_API_BASE_URL=http://localhost:4000

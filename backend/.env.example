PORT=4000
MONGO_URI=mongodb://localhost:27017/smartprep
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:5000
DAILY_SESSION_LIMIT=3

# ---- Email (for password reset OTP) ----
# For Gmail: turn on 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords  and paste it as EMAIL_PASS.
EMAIL_USER=your.address@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM="SmartPrep AI" <your.address@gmail.com>
# Optional (for non-Gmail SMTP):
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
